# nodejs-argo environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore.

# Subscription upload endpoint (optional)
UPLOAD_URL=

# Project domain assigned by PaaS platform (optional)
PROJECT_URL=https://www.google.com

# Enable keep-alive auto-access (optional, default: false)
AUTO_ACCESS=false

# HTTP server port (optional, default: 3000)
PORT=3000

# Argo tunnel port (optional, default: 8001)
ARGO_PORT=8001

# IMPORTANT: Generate a unique UUID for each deployment.
#   Linux/macOS: uuidgen
#   Node.js:     node -e "console.log(require('crypto').randomUUID())"
# Do NOT reuse the example UUID from the README.
UUID=

# Nezha monitoring panel (optional)
NEZHA_SERVER=
NEZHA_PORT=
NEZHA_KEY=

# Argo fixed tunnel credentials (optional — omit both for quick/temporary tunnels)
ARGO_DOMAIN=
ARGO_AUTH=

# Preferred Cloudflare IP / domain (optional)
CFIP=www.visa.com.tw
CFPORT=443

# Node name prefix (optional)
NAME=Vls

# Working directory (optional)
FILE_PATH=./tmp

# Subscription path (optional, default: sub)
SUB_PATH=sub
